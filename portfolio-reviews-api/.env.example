# MongoDB Atlas connection string (Step 1). Add a database name before the query string.
# mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/portfolio?appName=Cluster0
MONGO_URI=

# Comma-separated list of browser origins allowed to call this API (Step 4).
# Add your deployed portfolio domain here. localhost:5173/5174 are allowed automatically.
# Example: https://portfolio-sigma-seven-8hho4d2jsf.vercel.app
ALLOWED_ORIGINS=
